# Server settings
PORT=5000
DATABASE_PATH=./students.db
JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRES_IN=1d
NODE_ENV=development

# SMTP settings for OTP email delivery
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM=School Admin <no-reply@example.com>

# Note: backend/app.js loads environment variables from the current process.
# You can put these values in root .env or backend/.env if running from different folders.
